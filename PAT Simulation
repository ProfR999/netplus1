        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-3">
            <p>© 2026 Interactive Systems Design Portfolio. Built for Web Instructional Environments.</p>
            <div class="flex gap-4">
                <span class="hover:text-slate-400 cursor-help" onclick="alert('Simulation maps private inside local hosts using port overload mapping patterns.')">Specs</span>
                <span>•</span>
                <span class="hover:text-slate-400 cursor-help" onclick="resetAllStates()">Factory Reset</span>
            </div>
        </div>
    </footer>

    <!-- Embedded Scripts for Simulation Engine -->
    <script>
        // Global State Variables
        let currentSource = 'PC';
        let currentDest = 'Web';
        let simulationMode = 'auto'; // 'auto' | 'step'
        let currentStep = 0; // Steps 0 to 8 for cycle
        let natTable = [];
        let isAnimating = false;
        let animationFrameId = null;

        // Constants detailing devices and servers IPs/Ports
        const configurations = {
            PC: {
                name: "PC",
                insideLocalIP: "192.168.1.50",
                insideLocalPort: "49152",
                elementId: "node-PC"
            },
            Phone: {
                name: "Smart Phone",
                insideLocalIP: "192.168.1.80",
                insideLocalPort: "51002",
                elementId: "node-Phone"
            },
            Router: {
                lanIP: "192.168.1.1",
                wanIP: "203.0.113.88",
                mappedPort: "10024", // Assigned outbound WAN port for this transaction
                elementId: "node-Router"
            },
            Web: {
                name: "Web Server",
                outsideIP: "93.184.216.34",
                outsidePort: "80",
                elementId: "node-Web"
            },
            Game: {
                name: "Game Server",
                outsideIP: "198.51.100.42",
                outsidePort: "19132",
                elementId: "node-Game"
            }
        };

        // Tab Switching Logic
        function switchTab(tabId) {
            const tabs = ['simulation', 'glossary', 'quiz'];
            tabs.forEach(t => {
                const panel = document.getElementById(`panel-${t}`);
                const button = document.getElementById(`tab-${t}`);
                if (t === tabId) {
                    panel.classList.remove('hidden');
                    button.classList.add('bg-indigo-600', 'text-white', 'shadow-sm');
                    button.classList.remove('text-slate-400');
                } else {
                    panel.classList.add('hidden');
                    button.classList.remove('bg-indigo-600', 'text-white', 'shadow-sm');
                    button.classList.add('text-slate-400', 'hover:text-slate-200');
                }
            });
            // Stop any running animations on tab change
            stopAnimation();
        }

        // Selection Handlers
        function selectSource(sourceId) {
            if (isAnimating) return;
            currentSource = sourceId;
            const devices = ['PC', 'Phone'];
            devices.forEach(d => {
                const btn = document.getElementById(`src-${d}`);
                const element = document.getElementById(`node-${d}`);
                if (d === sourceId) {
                    btn.classList.add('border-indigo-600', 'bg-indigo-950/20', 'text-indigo-400');
                    btn.classList.remove('border-slate-700', 'bg-slate-900', 'text-slate-400');
                    element.classList.add('border-blue-500', 'bg-blue-950/20', 'pulse-node');
                    element.classList.remove('border-blue-800/40');
                } else {
                    btn.classList.remove('border-indigo-600', 'bg-indigo-950/20', 'text-indigo-400');
                    btn.classList.add('border-slate-700', 'bg-slate-900', 'text-slate-400');
                    element.classList.remove('border-blue-500', 'bg-blue-950/20', 'pulse-node');
                    element.classList.add('border-blue-800/40');
                }
            });
        }

        function selectDest(destId) {
            if (isAnimating) return;
            currentDest = destId;
            const servers = ['Web', 'Game'];
            servers.forEach(s => {
                const btn = document.getElementById(`dst-${s}`);
                const element = document.getElementById(`node-${s}`);
                if (s === destId) {
                    btn.classList.add('border-indigo-600', 'bg-indigo-950/20', 'text-indigo-400');
                    btn.classList.remove('border-slate-700', 'bg-slate-900', 'text-slate-400');
                    element.classList.add('border-orange-500', 'bg-orange-950/20');
                    element.classList.remove('border-orange-800/40');
                } else {
                    btn.classList.remove('border-indigo-600', 'bg-indigo-950/20', 'text-indigo-400');
                    btn.classList.add('border-slate-700', 'bg-slate-900', 'text-slate-400');
                    element.classList.remove('border-orange-500', 'bg-orange-950/20');
                    element.classList.add('border-orange-800/40');
                }
            });
        }

        // Translation Table Utilities
        function updateNatTableUI() {
            const body = document.getElementById('nat-table-body');
            if (natTable.length === 0) {
                body.innerHTML = `
                    <tr id="empty-nat-placeholder">
                        <td colspan="4" class="py-4 px-3 text-center text-slate-500 italic">
                            No active mappings. Initiate a request to witness table registration.
                        </td>
                    </tr>
                `;
                return;
            }

            body.innerHTML = natTable.map(entry => `
                <tr class="border-b border-slate-800 bg-slate-900/60 transition-colors duration-500 ${entry.highlight ? 'bg-emerald-950/50 text-emerald-300 font-bold' : ''}">
                    <td class="py-2.5 px-3 text-slate-400">${entry.protocol}</td>
                    <td class="py-2.5 px-3 text-blue-300">${entry.insideLocal}</td>
                    <td class="py-2.5 px-3 text-emerald-400">${entry.insideGlobal}</td>
                    <td class="py-2.5 px-3 text-orange-400">${entry.outsideGlobal}</td>
                </tr>
            `).join('');
        }

        function addNatEntry(local, global, outside) {
            // Check if mapping exists to avoid double entries
            const exists = natTable.some(e => e.insideLocal === local && e.outsideGlobal === outside);
            if (!exists) {
                natTable.push({
                    protocol: 'TCP',
                    insideLocal: local,
                    insideGlobal: global,
                    outsideGlobal: outside,
                    highlight: true
                });
                updateNatTableUI();
            }
        }

        // DOM Positioning Utility for animations
        function getRelativeCoordinates(element) {
            const canvas = document.querySelector('.relative.overflow-hidden.h-\\[420px\\]');
            const canvasRect = canvas.getBoundingClientRect();
            const elemRect = element.getBoundingClientRect();

            // Calculate center points relative to the parent diagram container
            const x = (elemRect.left + elemRect.width / 2) - canvasRect.left;
            const y = (elemRect.top + elemRect.height / 2) - canvasRect.top;

            return { x, y };
        }

        // Main Animation Engine controls
        function triggerPacketFlow(mode) {
            if (isAnimating) return;
            resetSimulation();
            simulationMode = mode;
            isAnimating = true;
            currentStep = 1;

            // Lock controls
            setControlsState(true);

            if (simulationMode === 'auto') {
                runAutoLoop();
            } else {
                runStepCycle();
            }
        }

        function setControlsState(locked) {
            document.getElementById('btn-auto').disabled = locked;
            document.getElementById('btn-step').disabled = locked;
            document.getElementById('btn-attack').disabled = locked;
            document.getElementById('src-PC').disabled = locked;
            document.getElementById('src-Phone').disabled = locked;
            document.getElementById('dst-Web').disabled = locked;
            document.getElementById('dst-Game').disabled = locked;
        }

        // Auto Loop Runner
        function runAutoLoop() {
            if (!isAnimating) return;

            executeStepAction(currentStep);

            if (currentStep < 8) {
                setTimeout(() => {
                    currentStep++;
                    runAutoLoop();
                }, 4000); // 4-second dwell per leg transition for visual parsing
            } else {
                setTimeout(() => {
                    completeSimulation();
                }, 3500);
            }
        }

        // Step-By-Step Handler
        function runStepCycle() {
            executeStepAction(currentStep);
            const promptBox = document.getElementById('next-step-prompt');
            
            if (currentStep < 8) {
                promptBox.classList.remove('hidden');
            } else {
                promptBox.classList.add('hidden');
                setTimeout(() => {
                    completeSimulation();
                }, 3000);
            }
        }

        function advanceStep() {
            document.getElementById('next-step-prompt').classList.add('hidden');
            currentStep++;
            runStepCycle();
        }

        function stopAnimation() {
            isAnimating = false;
            if (animationFrameId) {
                cancelAnimationFrame(animationFrameId);
            }
            const packetEl = document.getElementById('sim-packet');
            packetEl.style.opacity = '0';
            document.getElementById('live-header').style.opacity = '0';
            document.getElementById('next-step-prompt').classList.add('hidden');
            setControlsState(false);
        }

        function completeSimulation() {
            stopAnimation();
            document.getElementById('guide-title').innerText = "Process Complete 🎉";
            document.getElementById('guide-body').innerHTML = `
                The full bidirectional cycle was completed successfully. The internal device 
                received its return data payloads. The matching NAT routing entry remains 
                safely stored inside the router's active lookup table waiting for subsequent transactions.
            `;
            document.getElementById('step-badge').innerText = "IDLE";
            document.getElementById('step-badge').className = "px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-950 text-emerald-400";
            setControlsState(false);
        }

        // Core State Machine matching steps to coordinates, text, and changes
        function executeStepAction(stepNum) {
            const packetEl = document.getElementById('sim-packet');
            const liveHeader = document.getElementById('live-header');
            const liveSrc = document.getElementById('live-src');
            const liveDst = document.getElementById('live-dst');
            const stepBadge = document.getElementById('step-badge');

            const srcConf = configurations[currentSource];
            const dstConf = configurations[currentDest];
            const rtrConf = configurations.Router;

            // Compute actual coordinates on parent canvas for elements dynamically
            const posSource = getRelativeCoordinates(document.getElementById(srcConf.elementId));
            const posRouter = getRelativeCoordinates(document.getElementById(rtrConf.elementId));
            const posDest = getRelativeCoordinates(document.getElementById(dstConf.elementId));

            // Setup step badges
            stepBadge.innerText = `STEP ${stepNum}/8`;
            stepBadge.className = "px-2 py-0.5 rounded text-[10px] font-bold bg-indigo-950 text-indigo-400 animate-pulse";

            // Packet styles reset
            packetEl.classList.remove('packet-glow-err');
            packetEl.classList.add('packet-glow');
            packetEl.style.transition = "all 2500ms cubic-bezier(0.25, 1, 0.5, 1)";

            // Highlight router interfaces if needed
            const routerCard = document.getElementById(rtrConf.elementId);
            routerCard.className = "absolute left-[40%] top-[35%] w-[180px] bg-slate-900 border-2 border-emerald-500 rounded-2xl shadow-xl p-3 z-20 flex flex-col items-center transition-all duration-300";

            switch (stepNum) {
                case 1: // Generation & LAN Travel (Source -> Router)
                    document.getElementById('guide-title').innerText = "1. Packet Generation at Client";
                    document.getElementById('guide-body').innerHTML = `
                        The <strong>${srcConf.name}</strong> builds a standard outbound IP packet to talk to 
                        the <strong>${dstConf.name}</strong>. Because the destination IP address (<code class="bg-slate-800 text-amber-300 font-mono px-1 py-0.5 rounded">${dstConf.outsideIP}</code>) is 
                        external to the local subnet, the host forwards the packet directly to its local default gateway (the NAT Router).
                    `;

                    // Configure live packet header visuals
                    liveSrc.innerText = `${srcConf.insideLocalIP}:${srcConf.insideLocalPort}`;
                    liveDst.innerText = `${dstConf.outsideIP}:${dstConf.outsidePort}`;
                    liveHeader.style.opacity = '1';

                    // Position packet at source, wait briefly, then slide to Router
                    packetEl.style.transition = "none";
                    packetEl.style.left = `${posSource.x}px`;
                    packetEl.style.top = `${posSource.y}px`;
                    packetEl.style.opacity = '1';

                    setTimeout(() => {
                        packetEl.style.transition = "all 2200ms ease-in-out";
                        packetEl.style.left = `${posRouter.x - 40}px`;
                        packetEl.style.top = `${posRouter.y}px`;
                    }, 100);
                    break;

                case 2: // Inside Router Gateway Assessment
                    document.getElementById('guide-title').innerText = "2. Arrival & Table Inspection";
                    document.getElementById('guide-body').innerHTML = `
                        The packet arrives on the router's internal LAN Interface (<code class="bg-slate-800 text-blue-300 font-mono px-1 py-0.5 rounded">${rtrConf.lanIP}</code>). 
                        The router's OS detects that the packet must go onto the public internet, meaning <strong>Source Translation is required</strong>. 
                        It first checks if an active translation mapping already exists in memory.
                    `;

                    // Pulse Router element
                    routerCard.className = "absolute left-[40%] top-[35%] w-[180px] bg-slate-900 border-2 border-indigo-400 rounded-2xl shadow-2xl p-3 z-20 flex flex-col items-center transition-all scale-105 duration-300";

                    packetEl.style.left = `${posRouter.x}px`;
                    packetEl.style.top = `${posRouter.y}px`;
                    break;

                case 3: // NAT Table Insertion & Translation
                    document.getElementById('guide-title').innerText = "3. WAN Translation & Registry Mapping";
                    document.getElementById('guide-body').innerHTML = `
                        The router assigns a distinct external source port (<code class="bg-slate-800 text-emerald-400 font-mono px-1 py-0.5 rounded">${rtrConf.mappedPort}</code>) to this specific local client interface session. 
                        It logs the entry into its **NAT Translation Table** and swaps out the packet's **Private Source IP/Port** with its own **Public WAN IP/Port**.
                    `;

                    // Register mapping
                    addNatEntry(
                        `${srcConf.insideLocalIP}:${srcConf.insideLocalPort}`,
                        `${rtrConf.wanIP}:${rtrConf.mappedPort}`,
                        `${dstConf.outsideIP}:${dstConf.outsidePort}`
                    );

                    // Morph Header Visuals
                    liveSrc.innerHTML = `<span class="text-emerald-400 font-bold">${rtrConf.wanIP}:${rtrConf.mappedPort}</span> <span class="text-slate-500 line-through">(${srcConf.insideLocalIP}:${srcConf.insideLocalPort})</span>`;

                    packetEl.style.left = `${posRouter.x + 30}px`;
                    break;

                case 4: // Router -> Public Internet Server
                    document.getElementById('guide-title').innerText = "4. Traversing the WAN Space";
                    document.getElementById('guide-body').innerHTML = `
                        The translated packet, now showing a valid, routable **Inside Global** IP address as its source, 
                        is pushed onto the WAN carrier pipelines. The servers on the internet think the request originated 
                        directly from the router's WAN IP.
                    `;

                    packetEl.style.left = `${posDest.x}px`;
                    packetEl.style.top = `${posDest.y}px`;
                    break;

                case 5: // Server Reply Packet Construction
                    document.getElementById('guide-title').innerText = "5. Response Generation on Server";
                    document.getElementById('guide-body').innerHTML = `
                        The remote <strong>${dstConf.name}</strong> receives the data, processes the instruction, 
                        and crafts a payload reply. Crucially, the destination of this new packet is set to the 
                        router's public IP & designated WAN interface port (<code class="bg-slate-800 text-emerald-400 font-mono px-1 py-0.5 rounded">${rtrConf.wanIP}:${rtrConf.mappedPort}</code>).
                    `;

                    // Flip Header Direction (Source is Server, Dest is Router WAN)
                    liveSrc.innerText = `${dstConf.outsideIP}:${dstConf.outsidePort}`;
                    liveDst.innerText = `${rtrConf.wanIP}:${rtrConf.mappedPort}`;

                    packetEl.style.left = `${posDest.x}px`;
                    packetEl.style.top = `${posDest.y}px`;
                    break;

                case 6: // Return Leg: Server -> Router WAN
                    document.getElementById('guide-title').innerText = "6. Delivery Back to WAN Edge Gateway";
                    document.getElementById('guide-body').innerHTML = `
                        The packet travels back across the public internet. It arrives directly at the router's external 
                        WAN interface IP (<code class="bg-slate-800 text-orange-400 font-mono px-1 py-0.5 rounded">${rtrConf.wanIP}</code>). Standard firewalls would reject unsolicited packets, but the 
                        router must check its mapping tables first.
                    `;

                    packetEl.style.left = `${posRouter.x + 40}px`;
                    packetEl.style.top = `${posRouter.y}px`;
                    break;

                case 7: // Reverse Table Lookup & Untranslation
                    document.getElementById('guide-title').innerText = "7. Reverse Mapping Evaluation";
                    document.getElementById('guide-body').innerHTML = `
                        The router's core engine reads the destination port (<code class="bg-slate-800 text-emerald-400 font-mono px-1 py-0.5 rounded">${rtrConf.mappedPort}</code>). 
                        It references its active state table, matches the session to the local client (<code class="bg-slate-800 text-blue-300 font-mono px-1 py-0.5 rounded">${srcConf.insideLocalIP}:${srcConf.insideLocalPort}</code>), 
                        and **restores** the private destination header parameters.
                    `;

                    // Highlight the table row visually by temporarily altering active matching table records styles
                    natTable.forEach(e => {
                        if (e.insideLocal === `${srcConf.insideLocalIP}:${srcConf.insideLocalPort}`) {
                            e.highlight = true;
                        } else {
                            e.highlight = false;
                        }
                    });
                    updateNatTableUI();

                    // Restore Header values on screen
                    liveSrc.innerText = `${dstConf.outsideIP}:${dstConf.outsidePort}`;
                    liveDst.innerHTML = `<span class="text-blue-300 font-bold">${srcConf.insideLocalIP}:${srcConf.insideLocalPort}</span> <span class="text-slate-500 line-through">(${rtrConf.wanIP}:${rtrConf.mappedPort})</span>`;

                    packetEl.style.left = `${posRouter.x - 30}px`;
                    packetEl.style.top = `${posRouter.y}px`;
                    break;

                case 8: // Delivery: Router LAN -> Local Client
                    document.getElementById('guide-title').innerText = "8. Safe Local Delivery";
                    document.getElementById('guide-body').innerHTML = `
                        Now displaying the internal **Inside Local** address, the packet is placed on the local LAN broadcast bus. 
                        The target <strong>${srcConf.name}</strong> receives it seamlessly, unaware that its packets traveled across 
                        the vast public internet utilizing shared public resources!
                    `;

                    packetEl.style.left = `${posSource.x}px`;
                    packetEl.style.top = `${posSource.y}px`;
                    break;
            }
        }

        // Simulate Unsolicited Inbound Probe (Firewall/NAT demonstration)
        function triggerAttack() {
            if (isAnimating) return;
            isAnimating = true;
            setControlsState(true);

            const packetEl = document.getElementById('sim-packet');
            const liveHeader = document.getElementById('live-header');
            const liveSrc = document.getElementById('live-src');
            const liveDst = document.getElementById('live-dst');
            const stepBadge = document.getElementById('step-badge');

            const rtrConf = configurations.Router;
            const webConf = configurations.Web;

            const posRouter = getRelativeCoordinates(document.getElementById(rtrConf.elementId));
            const posWeb = getRelativeCoordinates(document.getElementById(webConf.elementId));

            stepBadge.innerText = "THREAT PROBE";
            stepBadge.className = "px-2 py-0.5 rounded text-[10px] font-bold bg-rose-950 text-rose-400 animate-pulse";

            document.getElementById('guide-title').innerText = "Security Probe Inbound";
            document.getElementById('guide-body').innerHTML = `
                An external system (represented by the Web Server here) tries to initiate an 
                <strong>unsolicited inbound connection</strong> directly targeting the Router WAN port 
                on random administrative Port <code class="bg-slate-800 text-rose-400 font-mono px-1 py-0.5 rounded">23</code> (SSH/Telnet port probe).
            `;

            // Prepare threat packet headers
            liveSrc.innerText = `${webConf.outsideIP}:44122`;
            liveDst.innerText = `${rtrConf.wanIP}:23`;
            liveHeader.style.opacity = '1';

            packetEl.classList.remove('packet-glow');
            packetEl.classList.add('packet-glow-err');
            packetEl.style.transition = "none";
            packetEl.style.left = `${posWeb.x}px`;
            packetEl.style.top = `${posWeb.y}px`;
            packetEl.style.opacity = '1';

            // Phase 1: Threat traveling to Router
            setTimeout(() => {
                packetEl.style.transition = "all 2000ms ease-in-out";
                packetEl.style.left = `${posRouter.x + 30}px`;
                packetEl.style.top = `${posRouter.y}px`;
            }, 100);

            // Phase 2: Router lookup fails & packet drops
            setTimeout(() => {
                document.getElementById('guide-title').innerText = "Probe Blocked & Dropped!";
                document.getElementById('guide-body').innerHTML = `
                    The router's interface receives the packet on external Port 23. It scans the NAT Translation Table. 
                    Because there is <strong>no mapping entry</strong> routing incoming Port 23 to any internal private host, 
                    the router immediately <strong>drops</strong> the packet. 
                    <br><br>
                    <span class="text-emerald-400 font-semibold">Key Takeaway:</span> NAT provides a powerful implicit security layer 
                    because it hides private machines behind a single gateway and drops all unmapped incoming traffic automatically!
                `;

                // Explode / Fade packet
                packetEl.style.transform = "scale(2.5)";
                packetEl.style.opacity = "0";

                // Highlight Router Card as alert state
                const rtrCard = document.getElementById(rtrConf.elementId);
                rtrCard.className = "absolute left-[40%] top-[35%] w-[180px] bg-slate-900 border-2 border-rose-500 rounded-2xl shadow-xl p-3 z-20 flex flex-col items-center transition-all duration-300";

                setTimeout(() => {
                    packetEl.style.transform = "scale(1)";
                    stopAnimation();
                    setControlsState(false);
                }, 1500);

            }, 2200);
        }

        // Global Reset
        function resetSimulation() {
            stopAnimation();
            natTable = [];
            updateNatTableUI();
            
            // Clean visual mappings highlights
            const pcEl = document.getElementById('node-PC');
            pcEl.className = "absolute left-[6%] top-[15%] flex items-center gap-3 bg-slate-900/90 border border-blue-800/40 p-3 rounded-xl";
            const phoneEl = document.getElementById('node-Phone');
            phoneEl.className = "absolute left-[6%] top-[60%] flex items-center gap-3 bg-slate-900/90 border border-blue-800/40 p-3 rounded-xl";
            const rtrEl = document.getElementById('node-Router');
            rtrEl.className = "absolute left-[40%] top-[35%] w-[180px] bg-slate-900 border-2 border-emerald-500 rounded-2xl shadow-xl p-3 z-20 flex flex-col items-center";

            // Restore defaults
            selectSource('PC');
            selectDest('Web');

            document.getElementById('guide-title').innerText = "Ready to transmit";
            document.getElementById('guide-body').innerHTML = `
                Select a sender device and server target above, then click either <strong>Auto Play</strong> to watch the transaction end-to-end, or <strong>Step-by-Step</strong> to dissect header transformations at each critical boundary.
            `;
            document.getElementById('step-badge').innerText = "IDLE";
            document.getElementById('step-badge').className = "px-2 py-0.5 rounded text-[10px] font-bold bg-slate-900 text-slate-400";
        }

        function resetAllStates() {
            resetSimulation();
            // Clear inputs in quiz
            const inputs = document.querySelectorAll('.question-box input[type="radio"]');
            inputs.forEach(i => i.checked = false);
            const explanations = document.querySelectorAll('.explanation-box');
            explanations.forEach(e => {
                e.classList.add('hidden');
                e.innerHTML = '';
            });
            document.getElementById('quiz-result').classList.add('hidden');
            alert('All simulation parameters, active configurations, and quiz inputs have been completely purged.');
        }

        // Interactive Assessment Check
        function checkAnswers() {
            const boxes = document.querySelectorAll('.question-box');
            let correctCount = 0;

            const quizRationales = [
                "<strong>Correct!</strong> Outbound NAT swaps the local private source parameter (e.g., 192.168.1.50:49152) with the router's public source parameter (203.0.113.88:10024) to ensure routing on the open web.",
                "<strong>Correct!</strong> The primary driver behind the proliferation of NAT/PAT was the conservation of the exhaustible IPv4 address space, postponing full global network migration requirements.",
                "<strong>Correct!</strong> A stateful firewall/NAT router drops all unsolicited inbound packets as a safety protocol unless an explicit mapping or port forwarding rule exists."
            ];

            boxes.forEach((box, index) => {
                const correctVal = box.getAttribute('data-correct');
                const selected = box.querySelector(`input[name="q${index+1}"]:checked`);
                const expBox = box.querySelector('.explanation-box');

                expBox.classList.remove('hidden');

                if (selected && selected.value === correctVal) {
                    correctCount++;
                    box.className = "bg-slate-900 p-5 rounded-xl border-2 border-emerald-500/50 question-box";
                    expBox.innerHTML = `<span class="text-emerald-400 font-bold">✔️ Correct!</span> <p class="text-slate-300 mt-1">${quizRationales[index]}</p>`;
                } else {
                    box.className = "bg-slate-900 p-5 rounded-xl border-2 border-rose-500/50 question-box";
                    expBox.innerHTML = `<span class="text-rose-400 font-bold">❌ Incorrect.</span> <p class="text-slate-300 mt-1">${quizRationales[index]}</p>`;
                }
            });

            const resultText = document.getElementById('quiz-result');
            resultText.classList.remove('hidden');
            resultText.innerHTML = `You scored ${correctCount} / ${boxes.length}!`;
            if (correctCount === boxes.length) {
                resultText.className = "text-sm font-bold text-emerald-400";
            } else {
                resultText.className = "text-sm font-bold text-amber-400";
            }
        }

        // Run setup on load
        window.addEventListener('DOMContentLoaded', () => {
            resetSimulation();
        });
    </script>
</body>
</html>


### Key Instructional Design Elements Included:
1. **Demonstration of PAT Multi-Device Architecture:** It features *both* a local client PC and a smartphone. Showing two devices routing through the same shared WAN interface illustrates *why* the port is translationally modified to preserve uniqueness.
2. **Implicit Security Demonstration:** An explicit threat simulation shows what happens during an unsolicited external port scan, clarifying how NAT provides passive packet-dropping firewall defense.
3. **Flexible Scaffolding:** Allows learners to toggle between fully automated pacing (with 4-second dwell times designed for processing visual movements) and learner-directed Step-by-Step advancement.
4. **Immediate Knowledge Integration:** The custom glossary and built-in knowledge check quiz give structured reinforcement and comprehensive rationales immediately after interaction.
